VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Server-only. Use the Supabase secret key (or legacy service-role key) only in API routes.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Server-only. Trigger.dev Cloud project in Frankfurt; payloads contain only opaque job IDs.
TRIGGER_PROJECT_REF=
TRIGGER_SECRET_KEY=
VITE_AI_USE_SERVER_PROXY=true
# Server-only. Never expose this as VITE_GOOGLE_API_KEY.
GOOGLE_API_KEY=
# Server-only. Provisioned by the Vercel Upstash integration; use an EU/Frankfurt database.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Server-only. Set a different high-entropy value for Development, Preview, and Production.
AI_PROTECTION_HMAC_KEY=

# Playwright Hosted-E2E only. Put real values in the ignored .env.e2e.local file or CI secrets.
# This must point to a separate Supabase test project and a pre-created test account.
# Local E2E does not need this file; npm run test:e2e:local reads loopback credentials from supabase status.
CORE_E2E_EMAIL=
CORE_E2E_PASSWORD=
# Explicit safety switch: the E2E setup replaces all cloud data owned by this test account.
CORE_E2E_ALLOW_ACCOUNT_RESET=false
