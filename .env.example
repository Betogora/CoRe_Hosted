VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_AI_USE_SERVER_PROXY=true
# Server-only. Never expose this as VITE_GOOGLE_API_KEY.
GOOGLE_API_KEY=

# Playwright Hosted-E2E only. Put real values in the ignored .env.e2e.local file or CI secrets.
# This must point to a separate Supabase test project and a pre-created test account.
# Local E2E does not need this file; npm run test:e2e:local reads loopback credentials from supabase status.
CORE_E2E_EMAIL=
CORE_E2E_PASSWORD=
# Explicit safety switch: the E2E setup replaces all cloud data owned by this test account.
CORE_E2E_ALLOW_ACCOUNT_RESET=false
