{
  "name": "core-menu-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json && tsx scripts/verifyTypePolicy.ts",
    "test": "tsx scripts/runModuleTests.ts unit contract integration",
    "test:unit": "tsx scripts/runModuleTests.ts unit",
    "test:contract": "tsx scripts/runModuleTests.ts contract",
    "test:integration": "tsx scripts/runModuleTests.ts integration",
    "test:unit-contract": "tsx scripts/runModuleTests.ts unit contract",
    "test:e2e": "playwright test",
    "test:e2e:golden:local": "tsx scripts/runLocalE2E.ts --gate=golden",
    "test:e2e:local": "tsx scripts/runLocalE2E.ts --gate=release",
    "test:pr:local": "tsx scripts/runLocalE2E.ts --gate=pr",
    "test:beta": "npm run typecheck && npm run test:unit-contract && npm run build && npm run test:integration && npm run test:beta:local",
    "test:beta:local": "tsx scripts/runLocalE2E.ts --gate=beta",
    "test:beta:hosted": "playwright test --config=playwright.hosted.config.ts --project=auth-setup && playwright test --config=playwright.hosted.config.ts --grep @hosted-core --no-deps",
    "test:release": "npm run typecheck && npm run test:unit-contract && npm run build && npm run test:release:local",
    "test:release:local": "npm run test:integration && tsx scripts/runLocalE2E.ts --gate=release && npm run benchmark:apkg",
    "test:rls:core:local": "tsx scripts/runLocalE2E.ts --gate=core-rls",
    "test:rls:local": "tsx scripts/runLocalE2E.ts --gate=rls",
    "db:types:generate": "tsx scripts/databaseTypes.ts --write",
    "db:types:check": "tsx scripts/databaseTypes.ts --check",
    "build": "vite build",
    "benchmark:apkg": "python scripts/create_world_capitals_apkg.py --benchmark-output test-results/apkg/m3-large-media.apkg && tsx scripts/benchmarkServerApkg.ts && tsx scripts/benchmarkApkgImport.ts",
    "postbuild": "tsx scripts/verifyBuildChunks.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.1",
    "@trigger.dev/sdk": "4.5.4",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fzstd": "^0.1.1",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tus-js-client": "4.3.1",
    "valibot": "1.4.2",
    "vite": "^7.0.0",
    "yauzl": "3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/yauzl": "3.4.0",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "6.2.5",
    "postcss": "^8.4.49",
    "supabase": "^2.109.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ws": "8.21.1"
  }
}
