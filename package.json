{
  "name": "core-menu-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json && node scripts/verifyTypePolicy.mjs",
    "test": "tsx --test \"src/**/*.test.{js,jsx,ts,tsx}\" \"api/**/*.test.{js,jsx,ts,tsx}\"",
    "test:e2e": "playwright test",
    "test:e2e:local": "node scripts/runLocalE2E.mjs",
    "test:rls:local": "node scripts/runLocalE2E.mjs --rls-only",
    "db:types:generate": "node scripts/databaseTypes.mjs --write",
    "db:types:check": "node scripts/databaseTypes.mjs --check",
    "build": "vite build",
    "postbuild": "node scripts/verifyBuildChunks.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.1",
    "@vitejs/plugin-react": "^5.0.0",
    "fzstd": "^0.1.1",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "supabase": "^2.109.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
