{
  "name": "core-menu-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json && tsx scripts/verifyTypePolicy.ts",
    "test": "tsx --test \"src/**/*.test.{ts,tsx}\" \"api/**/*.test.{ts,tsx}\"",
    "test:e2e": "playwright test",
    "test:e2e:local": "tsx scripts/runLocalE2E.ts",
    "test:rls:local": "tsx scripts/runLocalE2E.ts --rls-only",
    "db:types:generate": "tsx scripts/databaseTypes.ts --write",
    "db:types:check": "tsx scripts/databaseTypes.ts --check",
    "build": "vite build",
    "benchmark:apkg": "python scripts/create_world_capitals_apkg.py --benchmark-output test-results/apkg/m3-large-media.apkg && tsx scripts/benchmarkApkgImport.ts",
    "postbuild": "tsx scripts/verifyBuildChunks.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.110.1",
    "@upstash/ratelimit": "2.0.8",
    "@upstash/redis": "1.38.0",
    "@vitejs/plugin-react": "^5.0.0",
    "fzstd": "^0.1.1",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tus-js-client": "4.3.1",
    "valibot": "1.4.2",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "fake-indexeddb": "6.2.5",
    "postcss": "^8.4.49",
    "supabase": "^2.109.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
